rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID
    //   - displayName: string (required, immutable) - User display name
    //   - photoURL: string (optional) - User profile photo URL
    //
    // Collection: /chats/{chatId}
    // Fields:
    //   - title: string (optional) - Chat title
    //   - type: string (required, enum: ["one-on-one", "group"]) - Type of chat
    //   - createdAt: timestamp (required, immutable) - Creation timestamp
    //
    // Collection: /chats/{chatId}/messages/{messageId}
    // Fields:
    //   - senderId: string (required, immutable) - Sender's User UID
    //   - text: string (required, max 1000 chars) - Message content
    //   - timestamp: timestamp (required, immutable) - Message timestamp
    //   - readBy: list (required, items: string) - List of User UIDs who read this message
    //
    // Collection: /chats/{chatId}/participants/{participantId}
    // Fields:
    //   - userId: string (required, immutable) - User UID
    //   - joinedAt: timestamp (required, immutable) - Timestamp when user joined
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "thomaz.capila@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'role']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 2000));
    }

    function isValidChat(data) {
      return hasOnlyAllowedFields(['title', 'type', 'createdAt']) &&
             data.type in ['one-on-one', 'group'] &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['senderId', 'text', 'timestamp', 'readBy']) &&
             data.senderId is string &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.timestamp is timestamp &&
             data.readBy is list && data.readBy.size() < 100;
    }

    function isValidParticipant(data) {
      return hasOnlyAllowedFields(['userId', 'joinedAt']) &&
             data.userId is string &&
             data.joinedAt is timestamp;
    }

    function isValidKeywordsConfig(data) {
      return hasOnlyAllowedFields(['category_name', 'keywords', 'radius', 'icon']) &&
             data.category_name is string && data.category_name.size() > 0 && data.category_name.size() < 100 &&
             data.keywords is list && data.keywords.size() <= 20 &&
             data.radius is number && data.radius > 0 && data.radius <= 50000 &&
             data.icon is string && data.icon.size() < 100;
    }

    function isValidPlacesCache(data) {
      return hasOnlyAllowedFields(['place_id', 'name', 'lat', 'lng', 'rating', 'reviews', 'category', 'source_keyword', 'last_fetched']) &&
             data.place_id is string && data.place_id.size() > 0 && data.place_id.size() < 200 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.lat is number && data.lng is number &&
             (!('rating' in data) || data.rating is number) &&
             (!('reviews' in data) || data.reviews is number) &&
             (!('category' in data) || (data.category is string && data.category.size() < 100)) &&
             (!('source_keyword' in data) || (data.source_keyword is string && data.source_keyword.size() < 100)) &&
             data.last_fetched is timestamp;
    }

    function isValidPlacesControl(data) {
      return hasOnlyAllowedFields(['place_id', 'is_approved', 'is_hidden', 'custom_category', 'priority_score']) &&
             data.place_id is string && data.place_id.size() > 0 && data.place_id.size() < 200 &&
             data.is_approved is bool &&
             data.is_hidden is bool &&
             (!('custom_category' in data) || (data.custom_category is string && data.custom_category.size() < 100)) &&
             (!('priority_score' in data) || data.priority_score is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && areImmutableFieldsUnchanged(['uid', 'displayName']);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && exists(/databases/$(database)/documents/chats/$(chatId)/participants/$(request.auth.uid));
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && exists(/databases/$(database)/documents/chats/$(chatId)/participants/$(request.auth.uid));
        allow create: if isAuthenticated() && isValidMessage(request.resource.data) && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() && request.resource.data.readBy.hasAll(resource.data.readBy) && request.resource.data.readBy.size() == resource.data.readBy.size() + 1;
      }

      match /participants/{participantId} {
        allow read: if isAuthenticated() && exists(/databases/$(database)/documents/chats/$(chatId)/participants/$(request.auth.uid));
        allow create: if isAuthenticated() && isValidParticipant(request.resource.data);
      }
    }
  }
}
