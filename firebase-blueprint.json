{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" }
      },
      "required": ["uid", "displayName"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Represents a chat room (one-on-one or group).",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Chat title (for group chats)" },
        "type": { "type": "string", "enum": ["one-on-one", "group"], "description": "Type of chat" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["type", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Represents a message within a chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "Sender's User UID" },
        "text": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Message timestamp" },
        "readBy": { "type": "array", "items": { "type": "string" }, "description": "List of User UIDs who read this message" }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "Participant": {
      "title": "Participant",
      "description": "Links a user to a chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User UID" },
        "joinedAt": { "type": "string", "format": "date-time", "description": "Timestamp when user joined" }
      },
      "required": ["userId", "joinedAt"]
    },
    "KeywordsConfig": {
      "title": "KeywordsConfig",
      "description": "Admin configuration for map search categories.",
      "type": "object",
      "properties": {
        "category_name": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "radius": { "type": "number" },
        "icon": { "type": "string" }
      },
      "required": ["category_name", "keywords", "radius", "icon"]
    },
    "PlacesCache": {
      "title": "PlacesCache",
      "description": "Cached places from Google Maps API.",
      "type": "object",
      "properties": {
        "place_id": { "type": "string" },
        "name": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "category": { "type": "string" },
        "source_keyword": { "type": "string" },
        "last_fetched": { "type": "string", "format": "date-time" }
      },
      "required": ["place_id", "name", "lat", "lng", "last_fetched"]
    },
    "PlacesControl": {
      "title": "PlacesControl",
      "description": "Admin control over specific places.",
      "type": "object",
      "properties": {
        "place_id": { "type": "string" },
        "is_approved": { "type": "boolean" },
        "is_hidden": { "type": "boolean" },
        "custom_category": { "type": "string" },
        "priority_score": { "type": "number" }
      },
      "required": ["place_id", "is_approved", "is_hidden"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "Chat" },
      "description": "Chat rooms"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Messages in a chat"
    },
    "/chats/{chatId}/participants/{participantId}": {
      "schema": { "$ref": "Participant" },
      "description": "Participants in a chat"
    },
    "/keywords_config/{configId}": {
      "schema": { "$ref": "KeywordsConfig" },
      "description": "Map search keywords configuration"
    },
    "/places_cache/{placeId}": {
      "schema": { "$ref": "PlacesCache" },
      "description": "Cached Google Places"
    },
    "/places_control/{placeId}": {
      "schema": { "$ref": "PlacesControl" },
      "description": "Admin controls for places"
    }
  }
}
